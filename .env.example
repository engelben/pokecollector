# Initial bootstrap settings for the backend container
ADMIN_USERNAME=
ADMIN_PASSWORD=
JWT_SECRET_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TCGDEX_SYNC_LANGUAGES=en,de
PUBLIC_MODE=false
CORS_ORIGINS=

# Automatic safety backup before startup migrations on version changes
PRE_UPGRADE_BACKUP_ENABLED=true
PRE_UPGRADE_BACKUP_REQUIRED=true
PRE_UPGRADE_BACKUP_KEEP=10
